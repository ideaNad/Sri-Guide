{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "your-domain.com",
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=sriguide_db;Username=sriguide;Password=CHANGE_ME"
  },
  "JwtSettings": {
    "Issuer": "SriGuide",
    "Audience": "SriGuide_Client",
    "SecretKey": "REPLACE_WITH_LONG_RANDOM_SECRET"
  },
  "BrevoSettings": {
    "ApiKey": "YOUR_BREVO_API_KEY",
    "SenderEmail": "hello@your-domain.com",
    "SenderName": "SRIGuide Support"
  }
}
